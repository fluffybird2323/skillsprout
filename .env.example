# Environment Configuration for Manabu

# Groq API Key (Primary - Free Tier)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Fallback - Free Tier Available)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# API Endpoint (for production builds)
NEXT_PUBLIC_API_ENDPOINT=/api/ai

# App URL (used for OAuth redirects)
NEXT_PUBLIC_APP_URL=https://manabu.artiestudio.org

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=change-me-use-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-use-openssl-rand-hex-64

# Google OAuth
# https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://manabu.artiestudio.org/api/auth/google/callback

# X (Twitter) OAuth
# https://developer.twitter.com/ → Projects & Apps
X_CLIENT_ID=your_x_client_id_here
X_CLIENT_SECRET=your_x_client_secret_here
X_REDIRECT_URI=https://manabu.artiestudio.org/api/auth/x/callback

# Optional: Paid Search APIs for enhanced RAG (if not set, uses free Wikipedia/DuckDuckGo)
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here
# SERPER_API_KEY=your_serper_api_key_here
